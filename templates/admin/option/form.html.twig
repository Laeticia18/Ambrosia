{% extends 'admin/base_admin.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body %}
<div class="container">
    <p><a href="{{ path('admin_options') }}">← Retour aux options</a></p>
    <h1 class="page-title">{{ title }}</h1>

    <div class="form-card">
        {{ form_start(form) }}
            <div class="form-group">{{ form_label(form.name) }}{{ form_widget(form.name) }}{{ form_errors(form.name) }}</div>
            <div class="form-group">{{ form_label(form.extraPrice) }}{{ form_widget(form.extraPrice) }}{{ form_errors(form.extraPrice) }}</div>
            <div class="form-group" style="display:flex;align-items:center;gap:.7rem">
                {{ form_widget(form.isPaid) }}
                {{ form_label(form.isPaid) }}
            </div>
            <button type="submit" class="btn btn-primary">💾 Enregistrer</button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
