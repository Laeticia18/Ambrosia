{% extends 'base.html.twig' %}

{% block title %}La Carte{% endblock %}

{% block body %}
<div class="container">
    <h1 class="page-title">🥗 Notre Carte</h1>

    {% for category in categories %}
        <h2 class="section-title">{{ category.name }}</h2>
        {% if category.description %}
            <p style="color:var(--text-muted);margin-bottom:1rem">{{ category.description }}</p>
        {% endif %}

        <div class="cards-grid">
            {% for product in category.products %}
                <div class="card">
                    <div class="card__emoji">{{ product.image ?: '🥗' }}</div>
                    <div class="card__body">
                        <div class="card__title">{{ product.name }}</div>
                        <div class="card__desc">{{ product.description }}</div>
                        <div class="card__price">{{ product.basePrice|number_format(2, ',', ' ') }} €</div>
                        <a href="{{ path('app_product', {id: product.id}) }}" class="card__btn">Personnaliser →</a>
                    </div>
                </div>
            {% else %}
                <p style="color:var(--text-muted)">Aucun produit dans cette catégorie.</p>
            {% endfor %}
        </div>
    {% endfor %}
</div>
{% endblock %}
